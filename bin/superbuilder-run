#!/usr/bin/env bash
# Run the Superbuilder orchestrator. Builds (if needed) and dispatches.
# Use --build-only to build the orchestrator without starting a run.
set -euo pipefail

ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
ORCH="$ROOT/orchestrator"

build_only=0
args=()
for a in "$@"; do
  case "$a" in
    --build-only) build_only=1 ;;
    *) args+=("$a") ;;
  esac
done

if [[ ! -d "$ORCH/dist" ]]; then
  if [[ ! -d "$ORCH/node_modules" ]]; then
    (cd "$ORCH" && (command -v pnpm >/dev/null 2>&1 && pnpm install --frozen-lockfile 2>/dev/null) \
      || (command -v npm >/dev/null 2>&1 && npm install) ) >&2
  fi
  (cd "$ORCH" && npx tsc) >&2
fi

if [[ "$build_only" -eq 1 ]]; then
  echo "Orchestrator built at $ORCH/dist." >&2
  exit 0
fi

exec node "$ORCH/dist/index.js" run "${args[@]}"
