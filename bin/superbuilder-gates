#!/usr/bin/env bash
# Run quality gates for a single story via the orchestrator's hardened
# argv-form runGate (allow-list + FORBIDDEN_TOKENS regex enforced). Replaces
# the previous bash -c shell expansion which bypassed the security boundary.
#
# Usage: bin/superbuilder-gates <story-id> [--root <.superbuilder dir>] [--project <projectRoot>]
set -euo pipefail

ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
ORCH="$ROOT/orchestrator"

if [[ ! -d "$ORCH/dist" ]]; then
  if [[ ! -d "$ORCH/node_modules" ]]; then
    (cd "$ORCH" && (command -v pnpm >/dev/null 2>&1 && pnpm install --frozen-lockfile 2>/dev/null) \
      || (command -v npm >/dev/null 2>&1 && npm install) ) >&2
  fi
  (cd "$ORCH" && npx tsc) >&2
fi

exec node "$ORCH/dist/index.js" gates "$@"
