#!/usr/bin/env bash
# Run the Superbuilder self-heal evaluator. Builds (if needed) then dispatches
# to the orchestrator's `heal` verb. Writes the experiment JSON to
# .superbuilder/experiments/EXP-NNN.json (in the cwd by default) and prints it
# to stdout.
#
# Usage:
#   bin/superbuilder-heal --baseline-set <A|B> [--fixture-dir <path>] [--mutation <patch>]
#   bin/superbuilder-heal                       # defaults to --baseline-set B
set -euo pipefail

ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
ORCH="$ROOT/orchestrator"

if [[ ! -d "$ORCH/dist" ]]; then
  if [[ ! -d "$ORCH/node_modules" ]]; then
    (cd "$ORCH" && (command -v pnpm >/dev/null 2>&1 && pnpm install --frozen-lockfile 2>/dev/null) \
      || (command -v npm >/dev/null 2>&1 && npm install) ) >&2
  fi
  (cd "$ORCH" && npx tsc) >&2
fi

exec node "$ORCH/dist/index.js" heal "$@"
