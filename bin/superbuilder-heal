#!/usr/bin/env bash
# Self-heal is invoked through Claude Code via /superbuilder:superheal,
# which runs the 10-self-improve skill and dispatches the
# self-improvement-researcher agent. This bin script exists as a stable
# entry-point for future direct CLI use; today it prints guidance.
set -euo pipefail

cat >&2 <<'EOF'
superbuilder-heal: self-healing runs through the Claude Code slash command.

  In a Claude Code session, run:
      /superbuilder:superheal "<problem statement>"

The command invokes the 10-self-improve skill which enforces the
baseline → one mutation → fixed eval → keep/revert protocol.
Direct CLI invocation is reserved; not yet implemented.
EOF
exit 0
