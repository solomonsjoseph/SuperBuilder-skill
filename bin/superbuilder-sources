#!/usr/bin/env bash
# Run the Superbuilder source-update auditor. Builds (if needed) then dispatches
# to the orchestrator's `sources` verb. Writes .superbuilder/source-audits/AUDIT-<ts>.md.
set -euo pipefail

ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
ORCH="$ROOT/orchestrator"

if [[ ! -d "$ORCH/dist" ]]; then
  if [[ ! -d "$ORCH/node_modules" ]]; then
    (cd "$ORCH" && (command -v pnpm >/dev/null 2>&1 && pnpm install --frozen-lockfile 2>/dev/null) \
      || (command -v npm >/dev/null 2>&1 && npm install) ) >&2
  fi
  (cd "$ORCH" && npx tsc) >&2
fi

exec node "$ORCH/dist/index.js" sources "$@"
